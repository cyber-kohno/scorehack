{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Scorehack",
  "version": "0.1.0",
  "identifier": "com.scorehack.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Scorehack",
        "width": 1400,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 800,
        "resizable": true,
        "visible": false
      },
      {
        "label": "splashscreen",
        "title": "Scorehack",
        "url": "splash.html",
        "width": 360,
        "height": 260,
        "resizable": false,
        "decorations": false,
        "transparent": false,
        "backgroundColor": "#101418",
        "center": true,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
